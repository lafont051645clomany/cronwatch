# cronwatch.toml.example — copy to cronwatch.toml and adjust as needed

history_dir = ".cronwatch"
log_level   = "INFO"

# ── Jobs ────────────────────────────────────────────────────────────────────

[[jobs]]
name     = "daily-backup"
schedule = "0 2 * * *"   # cron expression
timeout  = 7200           # seconds before job is considered timed-out
grace    = 600            # seconds of slack after expected start
enabled  = true

[[jobs]]
name     = "hourly-sync"
schedule = "0 * * * *"
timeout  = 300
grace    = 120
enabled  = true

[[jobs]]
name     = "weekly-report"
schedule = "0 8 * * 1"   # every Monday at 08:00
timeout  = 1800
grace    = 900
enabled  = true

# ── Alerts ──────────────────────────────────────────────────────────────────

[alerts]
smtp_host     = "smtp.example.com"
smtp_port     = 587
smtp_user     = "cronwatch@example.com"
smtp_password = "s3cr3t"
from_address  = "cronwatch@example.com"
to_addresses  = ["ops@example.com", "oncall@example.com"]
use_tls       = true

# ── Digest ───────────────────────────────────────────────────────────────────
# Periodic summary emails covering all (or selected) jobs.

[digest]
enabled   = true
schedule  = "daily"          # "hourly" | "daily" | "weekly"
recipient = "ops@example.com"
# job_names = ["daily-backup"]  # omit to include all jobs
